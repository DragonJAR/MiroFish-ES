# ===== LLM API Configuration =====
# Compatible con OpenAI SDK format - usa tu proveedor favorito
# Ejemplos: Z.ai, Alibaba Qwen, OpenAI, etc.
LLM_API_KEY=your_llm_api_key_here
LLM_BASE_URL=https://api.example.com/v1
LLM_MODEL_NAME=glm-5-turbo

# ===== Fallback LLM Provider (opcional) =====
# Se usa cuando el LLM principal falla
LLM_FALLBACK_API_KEY=your_fallback_api_key_here
LLM_FALLBACK_BASE_URL=https://api.fallback-provider.com/v1
LLM_FALLBACK_MODEL=your-fallback-model-name

# ===== Memory Backend Configuration =====
# "zep" = Zep Cloud (SaaS, requiere ZEP_API_KEY)
# "graphiti" = Graphiti + Neo4j (local, requiere NEO4J_PASSWORD)
MEMORY_BACKEND=zep

# ===== Zep Cloud Configuration (solo si MEMORY_BACKEND=zep) =====
# Obtén tu API key en: https://app.getzep.com/
ZEP_API_KEY=your_zep_api_key_here

# ===== Graphiti Configuration (solo si MEMORY_BACKEND=graphiti) =====
# Graphiti v0.28.x usa variables OPENAI_* para el LLM internamente
# Configura LLM_API_KEY, LLM_BASE_URL, LLM_MODEL_NAME arriba
# Estos se copiarán automáticamente a OPENAI_* por el script iniciar.sh
# Graphiti es compatible con cualquier API OpenAI-compatible (z.ai, Qwen, etc.)
# OPENAI_API_KEY=your_openai_api_key_here
# OPENAI_BASE_URL=https://api.example.com/v1
# OPENAI_MODEL_NAME=your-model-name

# Neo4j Configuration (requerido para Graphiti)
NEO4J_URI=bolt://localhost:7687
NEO4J_USER=neo4j
NEO4J_PASSWORD=mirofish.dragonjar

# ===== Flask Configuration =====
SECRET_KEY=your-secret-key-for-flask
FLASK_DEBUG=true
FLASK_HOST=0.0.0.0
FLASK_PORT=5001

# ===== OASIS Simulation Configuration =====
OASIS_DEFAULT_MAX_ROUNDS=10
